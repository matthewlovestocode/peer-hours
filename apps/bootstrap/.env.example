# Copy this file to apps/bootstrap/.env for local bootstrap-service configuration.
# Obtain this value from the local community node's GET /status response (the peerId field).
DISCOVERY_CORE_KEY=

# Optional values. These defaults are suitable for local development.
PORT=10001
COMMUNITY_ID=peer-hours/earth/US/CA/east-bay/oakland
COMMUNITY_NAME=Oakland Timebank
COMMUNITY_NODE_URL=http://127.0.0.1:10000

# Optional comma-separated fallback manifest endpoints.
# BOOTSTRAP_NODES=https://bootstrap-one.example.test/bootstrap,https://bootstrap-two.example.test/bootstrap

# Optional JSON array of independently pinned community receipt identities.
# COMMUNITY_RECEIPT_NODES=[]
