{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "tsBuildInfoFile": "tsconfig.tsbuildinfo",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../timebank-domain" },
    { "path": "../timebank-identity" },
    { "path": "../timebank-ledger" },
    { "path": "../timebank-settlement" }
  ]
}
